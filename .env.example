# Base del servidor n8n donde viven los webhooks (en local es http, NO https).
NEXT_PUBLIC_N8N_BASE=http://localhost:5678

# Supabase (dashboard + login/register).
# Usar la publishable / anon key (pública por diseño). La secret key NUNCA va al front.
# Estas mismas variables se usan para Supabase Auth (login, registro, confirmación por email).
# En Supabase > Authentication > URL Configuration configurá el Site URL y las Redirect URLs
# (p. ej. http://localhost:3000 y http://localhost:3000/auth/confirm) para que los links de
# confirmación de email funcionen en local.
NEXT_PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxx
