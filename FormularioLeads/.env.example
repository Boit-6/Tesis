# Base de los webhooks de n8n.
# Local:      http://localhost:5678
# Producción: la URL pública de tu instancia de n8n
NEXT_PUBLIC_N8N_BASE=http://localhost:5678

# Supabase — SOLO para el dashboard server-side (/dashboard).
# Project URL (Settings → API → Project URL). No es secreta.
NEXT_PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co

# service_role key (Settings → API → service_role → "Reveal").
# ⚠️ SECRETA: bypasea RLS. El .env.local real NO se commitea (ya está en .gitignore).
SUPABASE_SERVICE_ROLE_KEY=tu-service-role-key